# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-strong-random-secret

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Email Service (Resend)
# During development you can use Resend's sandbox sender:
# FROM_EMAIL=Acme <onboarding@resend.dev>
RESEND_API_KEY=re_...
FROM_EMAIL=Acme <onboarding@resend.dev>

# Admin emails (comma-separated)
ADMIN_EMAILS=admin@yourdomain.com

# Email verification gate. Required by default; set to "false" to disable
# (e.g. local dev without outbound email). When on, users must verify their
# email before they can generate documents.
# REQUIRE_EMAIL_VERIFICATION=false

# Rate limiting (Upstash Redis). Create a free DB at upstash.com and copy these.
# If unset, rate limiting is disabled (fine for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Polar billing (all from the SAME Polar org/environment as POLAR_SERVER)
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=polar_oat_...
# One product id per paid plan. POLAR_PRODUCT_ID (legacy) is still honoured as Pro.
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_POWER=
POLAR_WEBHOOK_SECRET=

